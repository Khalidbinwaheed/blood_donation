# GitHub Models (server-side via Cloud Functions — token never in client)
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini
GITHUB_API_VERSION=2022-11-28

# Set token on Firebase only:
#   .\scripts\set-function-secrets.ps1
# Or manually:
#   firebase functions:secrets:set GITHUB_MODELS_TOKEN --project blooddonation-89361

USE_CLOUD_CHAT=true
ALLOW_CLIENT_OPENAI=false

# Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_MAPS_API_KEY=your-google-maps-and-places-key
GOOGLE_WEB_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Optional external backends (app falls back to Firestore/local when empty)
NEWS_API_URL=
NEWS_API_KEY=
PLACES_API_URL=
CHATBOT_API_URL=
BACKEND_URL=

APP_SHARE_URL=https://blooddonation-89361.web.app
PRIVACY_POLICY_URL=https://blooddonation-89361.web.app/privacy
REGION=US
LANG=en
